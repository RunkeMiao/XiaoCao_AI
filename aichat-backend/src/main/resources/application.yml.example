spring:
  application:
    name: aichat-backend

  ai:
    openai:
      base-url: https://api.siliconflow.cn
      api-key: ${AI_API_KEY:sk-xxx_replace_with_real_key}
      chat:
        model: nex-agi/Nex-N2-Pro
        temperature: 0.7

  data:
    redis:
      host: ${REDIS_HOST:localhost}
      port: ${REDIS_PORT:6379}
      password: ${REDIS_PASSWORD:your_password_here}
      database: 0

server:
  port: 8080
