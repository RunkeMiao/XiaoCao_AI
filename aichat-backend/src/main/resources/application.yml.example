# ============================================
# XiaoCao AI 后端配置文件模板
# ============================================
# 使用方法：
# 1. 复制本文件为 application.yml
# 2. 替换下面的环境变量默认值，或设置系统环境变量
# 3. 不要将包含真实密钥的 application.yml 提交到 Git

spring:
  application:
    name: aichat-backend

  # AI 配置（Spring AI OpenAI 兼容）
  ai:
    openai:
      # AI API 地址
      base-url: ${AI_BASE_URL:https://api.siliconflow.cn}
      # AI API 密钥（必填）
      api-key: ${AI_API_KEY:sk-xxx_replace_with_real_key}
      chat:
        # 模型名称
        model: ${AI_MODEL:zai-org/GLM-5.2}
        # 温度参数（0-1，越大越随机）
        temperature: ${AI_TEMPERATURE:0.7}
      # HTTP 超时配置见 ChatConfig.java (OpenAiHttpClientBuilderCustomizer)

  # 数据源配置
  datasource:
    # JDBC 连接地址（请替换数据库名和地址）
    url: ${DB_URL:jdbc:mysql://localhost:3306/aichat?useUnicode=true&characterEncoding=utf-8&serverTimezone=Asia/Shanghai}
    # 数据库用户名
    username: ${DB_USERNAME:root}
    # 数据库密码
    password: ${DB_PASSWORD:your_password_here}
    # JDBC 驱动
    driver-class-name: com.mysql.cj.jdbc.Driver

  # JPA 配置
  jpa:
    hibernate:
      # 自动建表策略：update=增量更新, create=每次重建, none=不自动
      ddl-auto: ${JPA_DDL_AUTO:update}
    # 打印 SQL（生产环境建议关闭）
    show-sql: ${JPA_SHOW_SQL:true}
    properties:
      hibernate:
        format_sql: true

  # Redis 配置
  data:
    redis:
      # Redis 主机地址
      host: ${REDIS_HOST:localhost}
      # Redis 端口
      port: ${REDIS_PORT:6379}
      # Redis 密码（如果没有密码，设为空字符串）
      password: ${REDIS_PASSWORD:your_password_here}
      # Redis 数据库编号
      database: ${REDIS_DATABASE:0}

  # 邮件配置（用于发送验证码）
  mail:
    # SMTP 服务器地址
    host: ${MAIL_HOST:smtp.qq.com}
    # SMTP 端口（587=STARTTLS, 465=SSL）
    port: ${MAIL_PORT:587}
    # 发件人邮箱
    username: ${MAIL_USERNAME:your_email@qq.com}
    # 邮箱授权码（非登录密码）
    password: ${MAIL_PASSWORD:your_email_authorization_code}
    properties:
      mail:
        smtp:
          # 启用 SMTP 认证
          auth: true
          starttls:
            # 启用 STARTTLS
            enable: true

# 必应股票 API 配置
biying:
  # API 基础地址
  base-url: ${BIYING_BASE_URL:https://api.biyingapi.com}
  # API 许可证密钥（必填）
  licence: ${BIYING_LICENCE:your_licence_here}

# 服务器配置
server:
  # 服务端口
  port: ${SERVER_PORT:8080}

# JWT 配置
jwt:
  # 签名密钥（生产环境务必替换为随机长字符串，至少 32 字节）
  secret: ${JWT_SECRET:your-jwt-secret-key-at-least-32-bytes-long!!}
  # Access Token 有效期（毫秒，默认 1 小时）
  access-expiration: ${JWT_ACCESS_EXPIRATION:3600000}
  # Refresh Token 有效期（毫秒，默认 7 天）
  refresh-expiration: ${JWT_REFRESH_EXPIRATION:604800000}

# Cookie 配置
cookie:
  # 是否设置 Secure 标志（生产环境 HTTPS 时设为 true）
  secure: ${COOKIE_SECURE:false}
